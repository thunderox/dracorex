@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ui: <http://lv2plug.in/ns/extensions/ui#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .

<http://nickbailey.co.nr/plugins/dracorex>
	a lv2:Plugin ;
	lv2:binary <dracorex@LIB_EXT@> ;
	rdfs:seeAlso <dracorex.ttl> .

<http://nickbailey.co.nr/plugins/dracorex#ui>
	a <@UI_TYPE@> ;
	ui:binary <dracorex_ui@LIB_EXT@> ;
	rdfs:seeAlso <dracorex.ttl> .
	
<dracorex-presets.lv2/nice.ttl>
	a pset:Preset ;
	rdfs:seeAlso <dracorex-presets.lv2/nice.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/dracorex> .
	
<dracorex-presets.lv2/synthwave_pad.ttl>
	a pset:Preset ;
	rdfs:seeAlso <dracorex-presets.lv2/synthwave_pad.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/dracorex> .
	
<dracorex-presets.lv2/vox_pad.ttl>
	a pset:Preset ;
	rdfs:seeAlso <dracorex-presets.lv2/vox_pad.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/dracorex> .
	
<dracorex-presets.lv2/vox_pad_2.ttl>
	a pset:Preset ;
	rdfs:seeAlso <dracorex-presets.lv2/vox_pad_2.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/dracorex> .

<dracorex-presets.lv2/warm_pad.ttl>
	a pset:Preset ;
	rdfs:seeAlso <dracorex-presets.lv2/warm_pad.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/dracorex> .
